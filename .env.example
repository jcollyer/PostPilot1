# ----------------------------------------------------------------------------
# Database (Neon Postgres)
# ----------------------------------------------------------------------------
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct connection (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ----------------------------------------------------------------------------
# Better Auth
# ----------------------------------------------------------------------------
# Secret used to sign sessions. Generate with: openssl rand -base64 32
# (BETTER_AUTH_SECRET takes precedence; AUTH_SECRET is accepted as a fallback.)
AUTH_SECRET=""
# Public origin of the web app, e.g. http://localhost:3000 in dev.
# (BETTER_AUTH_URL takes precedence; AUTH_URL is accepted as a fallback.)
AUTH_URL="http://localhost:3000"

# Optional explicit Better Auth overrides (otherwise the AUTH_* values above
# are used):
# BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL="http://localhost:3000"

# Custom URL scheme of the Expo mobile app (must match apps/mobile/app.json).
# Defaults to "saas" if unset.
# MOBILE_APP_SCHEME="saas"

# Email/password is the primary sign-in method. Signups require email
# verification, sent via Resend — https://resend.com/api-keys
AUTH_RESEND_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# Google OAuth (optional, "later" — only registers when both are set)
#   
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ----------------------------------------------------------------------------
# Platform connections (chunk 3)
# ----------------------------------------------------------------------------
# Encrypts OAuth tokens at rest (AES-256-GCM). REQUIRED to connect accounts.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# TikTok (Login Kit / Content Posting API). Sandbox and prod use different
# client keys; TIKTOK_ENV selects which pair is used ("sandbox" | "prod").
TIKTOK_ENV="sandbox"
TIKTOK_CLIENT_KEY_SANDBOX=""
TIKTOK_CLIENT_SECRET_SANDBOX=""
TIKTOK_CLIENT_KEY_PROD=""
TIKTOK_CLIENT_SECRET_PROD=""
# Optional: overrides the default ${AUTH_URL}/api/connections/tiktok/callback
TIKTOK_REDIRECT_URI=""

# Instagram (API with Instagram Login — Business/Creator accounts)
IG_CLIENT_ID=""
IG_CLIENT_SECRET=""
IG_REDIRECT_URI=""

# YouTube (Google OAuth — keep separate from the login Google client above).
# Enable the YouTube Data API v3 on the project and add the youtube.upload +
# youtube.readonly scopes. Only registers when both id and secret are set.
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI=""
