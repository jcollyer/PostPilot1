{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "AUTH_SECRET",
    "AUTH_URL",
    "AUTH_TRUST_HOST",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_RESEND_KEY",
    "EMAIL_FROM",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "MOBILE_APP_SCHEME",
    "TOKEN_ENCRYPTION_KEY",
    "TIKTOK_ENV",
    "TIKTOK_CLIENT_KEY_SANDBOX",
    "TIKTOK_CLIENT_SECRET_SANDBOX",
    "TIKTOK_CLIENT_KEY_PROD",
    "TIKTOK_CLIENT_SECRET_PROD",
    "TIKTOK_REDIRECT_URI",
    "IG_CLIENT_ID",
    "IG_CLIENT_SECRET",
    "IG_REDIRECT_URI",
    "YOUTUBE_CLIENT_ID",
    "YOUTUBE_CLIENT_SECRET",
    "YOUTUBE_REDIRECT_URI",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
